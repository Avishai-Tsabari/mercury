# ─── Auth Keys ─────────────────────────────────────────────────────────
# Required: one provider key (MERCURY_ prefix stripped when passed to container)
MERCURY_ANTHROPIC_API_KEY=
# MERCURY_ANTHROPIC_OAUTH_TOKEN=
# MERCURY_OPENAI_API_KEY=

# ─── Identity ──────────────────────────────────────────────────────────
MERCURY_BOT_USERNAME=mercury
MERCURY_PORT=8787
MERCURY_TRIGGER_PATTERNS=@Mercury

# ─── Model ─────────────────────────────────────────────────────────────
MERCURY_MODEL_PROVIDER=anthropic
MERCURY_MODEL=claude-opus-4-8

# Optional fallback when primary model fails (e.g. quota exceeded)
# MERCURY_MODEL_FALLBACK_PROVIDER=openai
# MERCURY_MODEL_FALLBACK=gpt-4o-mini

# Ordered model chain (JSON array). When set, overrides primary+fallback pair. Max 4 legs.
# MERCURY_MODEL_CHAIN=[{"provider":"anthropic","model":"claude-opus-4-8"},{"provider":"openai","model":"gpt-4o-mini"}]

# Retries per chain leg for transient errors only (default 2 => up to 3 attempts per leg).
# MERCURY_MODEL_MAX_RETRIES_PER_LEG=2

# Wall-clock budget for the whole chain (ms). Clamped below MERCURY_CONTAINER_TIMEOUT_MS - 10s.
# MERCURY_MODEL_CHAIN_BUDGET_MS=120000

# ─── Runtime ───────────────────────────────────────────────────────────
MERCURY_DATA_DIR=.mercury
MERCURY_MAX_CONCURRENCY=2
MERCURY_LOG_LEVEL=info

# ─── Container Runtime ─────────────────────────────────────────────────
# OCI runtime for inner (pi) containers.
# "runc" (default): standard Docker runtime; uses bubblewrap inside the container for sandboxing.
# "runsc": gVisor runtime — intercepts all syscalls at a user-space kernel boundary.
#   Stronger isolation than bwrap; enables full Docker hardening (no SYS_ADMIN relaxation needed).
#   Requires gVisor installed on the compute node (auto-installed by cloud-init on provisioned nodes).
# MERCURY_CONTAINER_RUNTIME=runc

# ─── Agent Container Image ─────────────────────────────────────────────
# Preset (from GitHub Container Registry):
#   ghcr.io/avishai-tsabari/mercury-agent:latest   - Full: Node, Python, Go, git (~2.8GB)
# Or build locally: ./container/build.sh
# Custom images must have: bun, pi, agent-browser, napkin, mercury-ctl
# See docs/container-lifecycle.md for custom image requirements
MERCURY_AGENT_IMAGE=ghcr.io/avishai-tsabari/mercury-agent:latest

# Optional: pi auth file path (default: <dataDir>/global/auth.json)
# MERCURY_AUTH_PATH=

# Optional: admin caller IDs (comma-separated)
# MERCURY_ADMINS=

# ─── Container Passthrough ─────────────────────────────────────────────
# All MERCURY_* vars are passed to containers with prefix stripped.
# Example: MERCURY_MY_API_KEY=xxx becomes MY_API_KEY=xxx in container

# ─── WhatsApp Ingress ──────────────────────────────────────────────────
MERCURY_ENABLE_WHATSAPP=false
# MERCURY_WHATSAPP_AUTH_DIR=  # default: <dataDir>/whatsapp-auth
# MERCURY_WHATSAPP_DEVICE_NAME=  # default: "Mercury" — shown in WhatsApp linked-devices list

# ─── Slack Ingress ─────────────────────────────────────────────────────
MERCURY_ENABLE_SLACK=false
MERCURY_SLACK_BOT_TOKEN=
MERCURY_SLACK_SIGNING_SECRET=

# ─── Discord Ingress ───────────────────────────────────────────────────
MERCURY_ENABLE_DISCORD=false
MERCURY_DISCORD_BOT_TOKEN=

# ─── Telegram Ingress ─────────────────────────────────────────────────
MERCURY_ENABLE_TELEGRAM=false
MERCURY_TELEGRAM_BOT_TOKEN=
# MERCURY_TELEGRAM_FORMAT_ENABLED=true   # convert Markdown to HTML for formatted replies
# MERCURY_TELEGRAM_WEBHOOK_SECRET_TOKEN=  # optional, for webhook verification
